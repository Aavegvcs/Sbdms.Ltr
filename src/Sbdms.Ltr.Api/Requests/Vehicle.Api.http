@HostAddress = http://localhost:5154

### Get all vehicles
GET {{HostAddress}}/api/v1/vehicle
Accept: application/json

### Get vehicle by id (int, auto-incremented)
@vehicleId = 1

GET {{HostAddress}}/api/v1/vehicle/{{vehicleId}}
Accept: application/json

### Add vehicle
# vendorId must be an existing Vendor.Id (create via Vendor.Api.http — Id 1 is seeded by the AddVendorAndVehicleDetails migration),
# vehicleTypeCode must be an existing VehicleType.VehicleTypeCode, currentStatusId an existing CurrentStatus.Id,
# driverId (optional) an existing Driver.Id (create these first via VehicleType/CurrentStatus/Driver .http files)
POST {{HostAddress}}/api/v1/vehicle
Content-Type: application/json

{
  "vendorId": 1,
  "vehicleTypeCode": 1,
  "driverId": null,
  "currentStatusId": 1,
  "vehicleNumber": "DL-01-AB-1234",
  "vehicleCompany": "Toyota",
  "modal": "Innova",
  "qrUniqueCode": "QR-001"
}

### Update vehicle
# Replace {{vehicleId}} above with the id returned from "Add vehicle" before running this.
PUT {{HostAddress}}/api/v1/vehicle/{{vehicleId}}
Content-Type: application/json

{
  "id": {{vehicleId}},
  "vendorId": 1,
  "vehicleTypeCode": 1,
  "driverId": 1,
  "currentStatusId": 1,
  "vehicleNumber": "DL-01-AB-1234",
  "vehicleCompany": "Toyota",
  "modal": "Innova Crysta",
  "qrUniqueCode": "QR-001-UPDATED"
}

### Add vehicle with duplicate QR code (expect 409 Conflict)
POST {{HostAddress}}/api/v1/vehicle
Content-Type: application/json

{
  "vendorId": 1,
  "vehicleTypeCode": 1,
  "driverId": null,
  "currentStatusId": 1,
  "vehicleNumber": "DL-01-AB-5678",
  "vehicleCompany": "Toyota",
  "modal": "Innova",
  "qrUniqueCode": "QR-001-UPDATED"
}

### Add vehicle with unknown vehicleTypeCode (expect 400 validation error)
POST {{HostAddress}}/api/v1/vehicle
Content-Type: application/json

{
  "vendorId": 1,
  "vehicleTypeCode": 999,
  "driverId": null,
  "currentStatusId": 1,
  "vehicleNumber": "DL-01-AB-5678",
  "vehicleCompany": "Toyota",
  "modal": "Innova",
  "qrUniqueCode": "QR-002"
}

### Add vehicle with unknown driverId (expect 400 validation error)
POST {{HostAddress}}/api/v1/vehicle
Content-Type: application/json

{
  "vendorId": 1,
  "vehicleTypeCode": 1,
  "driverId": 999,
  "currentStatusId": 1,
  "vehicleNumber": "DL-01-AB-5678",
  "vehicleCompany": "Toyota",
  "modal": "Innova",
  "qrUniqueCode": "QR-003"
}

### Add vehicle with unknown vendorId (expect 400 validation error)
POST {{HostAddress}}/api/v1/vehicle
Content-Type: application/json

{
  "vendorId": 999,
  "vehicleTypeCode": 1,
  "driverId": null,
  "currentStatusId": 1,
  "vehicleNumber": "DL-01-AB-5678",
  "vehicleCompany": "Toyota",
  "modal": "Innova",
  "qrUniqueCode": "QR-004"
}

### Get vehicle by unknown id (expect 404 Not Found)
GET {{HostAddress}}/api/v1/vehicle/999999
Accept: application/json

### Get vehicle + driver details by QR code (public — used right after a scan)
# Response shape: { "vehicle": { ...VehicleResponse }, "driver": { ...DriverResponse } | null }
# driver is null if the vehicle has no driverId assigned.
GET {{HostAddress}}/api/v1/vehicle/qr/QR-455c43ae51274cbfa
Accept: application/json

### Get a printable QR code image for a vehicle (returns image/png)
# In VS Code / Visual Studio's REST client this renders inline as an image.
GET {{HostAddress}}/api/v1/vehicle/{{vehicleId}}/qr-image

### Regenerate this vehicle's QR code — old code stops resolving, response has the new one
POST {{HostAddress}}/api/v1/vehicle/{{vehicleId}}/qr/regenerate

#####################################################################
# Change vehicle-driver pairing (logs the old mapping before overwriting it)
#####################################################################

### Reassign this vehicle to a different driver
# Response is the updated vehicle; the mapping being replaced is snapshotted into
# VehicleDriverAssignmentLogs first.
PUT {{HostAddress}}/api/v1/vehicle/2/driver
Content-Type: application/json

{
  "driverId": 1
}

### Unassign this vehicle's driver entirely
PUT {{HostAddress}}/api/v1/vehicle/{{vehicleId}}/driver
Content-Type: application/json

{
  "driverId": null
}

### Reassign with an unknown driverId (expect 400 validation error)
PUT {{HostAddress}}/api/v1/vehicle/{{vehicleId}}/driver
Content-Type: application/json

{
  "driverId": 999999
}

### View this vehicle's driver re-assignment history, most recent first
GET {{HostAddress}}/api/v1/vehicle/{{vehicleId}}/driver-history

#####################################################################
# Vehicle location — VehicleLocations holds only the latest position (fast lookups);
# every report is also appended forever to VehicleLocationHistories.
#####################################################################

@internalApiKey = abec10c209704c0b072ed672c60c61bfd9bdc624672e30cb3d379da6561bc687

### Report/update a vehicle's current position (upsert) — called by the GPS device itself,
# which identifies the vehicle by its registration number, not our internal id.
# Gated by X-Internal-Api-Key instead of a user JWT (the device has no user identity).
POST {{HostAddress}}/api/v1/vehicle/location
Content-Type: application/json
X-Internal-Api-Key: {{internalApiKey}}

{
  "vehicleNumber": "dl123h477",
  "latitude": 28.6139,
  "longitude": 77.2090
}

### Report without the API key (expect 401 Unauthorized)
POST {{HostAddress}}/api/v1/vehicle/location
Content-Type: application/json

{
  "vehicleNumber": "dl123h477",
  "latitude": 28.6139,
  "longitude": 77.2090
}

### Report with the wrong API key (expect 401 Unauthorized)
POST {{HostAddress}}/api/v1/vehicle/location
Content-Type: application/json
X-Internal-Api-Key: not-the-real-key

{
  "vehicleNumber": "dl123h477",
  "latitude": 28.6139,
  "longitude": 77.2090
}

### Report a location for an unknown vehicleNumber (expect 404 Not Found)
POST {{HostAddress}}/api/v1/vehicle/location
Content-Type: application/json
X-Internal-Api-Key: {{internalApiKey}}

{
  "vehicleNumber": "DOES-NOT-EXIST",
  "latitude": 28.6139,
  "longitude": 77.2090
}

### Report an out-of-range latitude (expect 500 — domain throws ArgumentException, not caught as a clean error)
POST {{HostAddress}}/api/v1/vehicle/location
Content-Type: application/json
X-Internal-Api-Key: {{internalApiKey}}

{
  "vehicleNumber": "DL-01-AB-1234",
  "latitude": 200,
  "longitude": 77.2090
}

### Get this vehicle's current position
GET {{HostAddress}}/api/v1/vehicle/{{vehicleId}}/location
Accept: application/json

### Get location for a vehicle that's never reported one (expect 404 Not Found)
GET {{HostAddress}}/api/v1/vehicle/999999/location
Accept: application/json

### Get every position ever reported for this vehicle, most recent first
GET {{HostAddress}}/api/v1/vehicle/{{vehicleId}}/location/history
Accept: application/json
